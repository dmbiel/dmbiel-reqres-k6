{
  "name": "dmbiel-reqres-k6",
  "version": "1.0.0",
  "description": "API performance testing project for ReqRes using Grafana k6",
  "type": "module",
  "scripts": {
    "test:smoke": "k6 run --summary-export results/k6-summary-smoke.json scenarios/smoke.js",
    "test:load": "k6 run --summary-export results/k6-summary-load.json scenarios/load.js",
    "test:stress": "k6 run --summary-export results/k6-summary-stress.json scenarios/stress.js",
    "test:spike": "k6 run --summary-export results/k6-summary-spike.json scenarios/spike.js",
    "report:compare:smoke": "node scripts/compareK6Summary.js results/k6-summary-smoke.json baselines/k6-summary-smoke.baseline.json",
    "report:compare:load": "node scripts/compareK6Summary.js results/k6-summary-load.json baselines/k6-summary-load.baseline.json",
    "report:compare:stress": "node scripts/compareK6Summary.js results/k6-summary-stress.json baselines/k6-summary-stress.baseline.json",
    "report:compare:spike": "node scripts/compareK6Summary.js results/k6-summary-spike.json baselines/k6-summary-spike.baseline.json",
    "report:html:smoke": "node scripts/writeHtmlReport.js results/k6-summary-smoke.json results/k6-summary-smoke.html",
    "report:html:load": "node scripts/writeHtmlReport.js results/k6-summary-load.json results/k6-summary-load.html",
    "report:html:stress": "node scripts/writeHtmlReport.js results/k6-summary-stress.json results/k6-summary-stress.html",
    "report:html:spike": "node scripts/writeHtmlReport.js results/k6-summary-spike.json results/k6-summary-spike.html",
    "validate:baseline-comparison": "node scripts/validateBaselineComparison.js",
    "validate:html-report": "node scripts/validateHtmlReport.js"
  },
  "keywords": [
    "k6",
    "performance-testing",
    "load-testing",
    "api-testing",
    "qa-automation",
    "reqres"
  ],
  "author": "Dmytro Bieliaiev",
  "license": "MIT",
  "dependencies": {
    "k6": "^0.0.0"
  }
}
